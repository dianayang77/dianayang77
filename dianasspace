<svg width="800" height="130" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <style>
      @keyframes float {
        0%, 100% { transform: translateY(0px); }
        50%       { transform: translateY(-5px); }
      }
      @keyframes blink {
        0%, 100% { opacity: 1; }
        50%       { opacity: 0.15; }
      }
      @keyframes flicker {
        0%, 18%, 20%, 52%, 54%, 100% { opacity: 1; }
        19%, 53% { opacity: 0.5; }
      }
      @keyframes scanline {
        0%   { transform: translateY(-130px); }
        100% { transform: translateY(130px); }
      }
      .title-group { animation: float 4s ease-in-out infinite; }
      .title {
        font-family: 'Courier New', monospace;
        font-size: 44px;
        font-weight: 900;
        fill: #E3F2FD;
        letter-spacing: 6px;
        animation: flicker 6s linear infinite;
      }
      .subtitle {
        font-family: 'Courier New', monospace;
        font-size: 12px;
        fill: #78909C;
        letter-spacing: 5px;
      }
      .scanline {
        animation: scanline 4s linear infinite;
        opacity: 0.05;
      }
      .s1 { animation: blink 1.4s ease-in-out infinite; }
      .s2 { animation: blink 2.2s ease-in-out infinite 0.4s; }
      .s3 { animation: blink 1.7s ease-in-out infinite 0.8s; }
      .s4 { animation: blink 3.0s ease-in-out infinite 0.2s; }
      .s5 { animation: blink 1.1s ease-in-out infinite 1.1s; }
    </style>
    <filter id="glow">
      <feGaussianBlur stdDeviation="4" result="blur"/>
      <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
    </filter>
    <filter id="redglow">
      <feGaussianBlur stdDeviation="3" result="blur"/>
      <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
    </filter>
  </defs>

